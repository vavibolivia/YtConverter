<Window x:Class="YtConverter.App.Views.LicenseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="라이선스 / 업그레이드" Height="440" Width="520"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        FontSize="13">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="현재 플랜" FontWeight="Bold" FontSize="14"/>
        <TextBlock x:Name="TierText" Grid.Row="1" Margin="0,4,0,16" FontSize="16"/>

        <TextBlock Grid.Row="2" Text="Pro / Admin 키가 있다면 입력하세요" FontWeight="Bold"/>
        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,6,0,16">
            <TextBox x:Name="KeyBox" Width="320" Padding="6,4" VerticalContentAlignment="Center"/>
            <Button Content="적용" MinWidth="80" Padding="12,6" Margin="8,0,0,0" Click="Apply_Click"/>
        </StackPanel>

        <StackPanel Grid.Row="4">
            <TextBlock Text="플랜 비교" FontWeight="Bold" Margin="0,0,0,6"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="#CCC" BorderThickness="1" Padding="12" Margin="0,0,6,0">
                    <StackPanel>
                        <TextBlock Text="🆓 Free" FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="· 하루 3건" Margin="0,6,0,2"/>
                        <TextBlock Text="· 동시 1개"/>
                        <TextBlock Text="· 전 기능 체험"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" BorderBrush="#1976D2" BorderThickness="2" Padding="12" Margin="3,0,3,0" Background="#E3F2FD">
                    <StackPanel>
                        <TextBlock Text="💎 Pro" FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="· 무제한 변환" Margin="0,6,0,2"/>
                        <TextBlock Text="· 동시 3개"/>
                        <TextBlock Text="· 광고 없음"/>
                        <TextBlock Text="· ₩ 9,900 (일회성)" FontWeight="Bold" Margin="0,4,0,0"/>
                        <Button Content="구매하기 (모의)" Margin="0,8,0,0" Padding="8,4" Click="MockPurchase_Click"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" BorderBrush="#CCC" BorderThickness="1" Padding="12" Margin="6,0,0,0">
                    <StackPanel>
                        <TextBlock Text="👑 Admin" FontWeight="Bold" FontSize="15"/>
                        <TextBlock Text="· 무제한 + 동시 5개" Margin="0,6,0,2"/>
                        <TextBlock Text="· Windows 계정 'jjsuk' 자동"/>
                        <TextBlock Text="· 또는 마스터 키"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="닫기" MinWidth="90" Padding="12,6" Click="Close_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
