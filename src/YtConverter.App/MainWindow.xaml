<Window x:Class="YtConverter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="YouTube Converter" Height="620" Width="780"
        WindowStartupLocation="CenterScreen"
        FontSize="13">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Content="URL" Grid.Column="0"/>
            <TextBox Grid.Column="1"
                     Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.AutomationId="UrlTextBox"/>
            <Button Grid.Column="2" Content="붙여넣기" Command="{Binding PasteCommand}"
                    AutomationProperties.AutomationId="PasteButton"/>
        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="포맷" Width="80"/>
            <RadioButton Content="MP3 (오디오)" GroupName="Format" Margin="4,0,16,0"
                         IsChecked="{Binding IsMp3Selected}"
                         VerticalContentAlignment="Center"
                         AutomationProperties.AutomationId="Mp3Radio"/>
            <RadioButton Content="MP4 (영상)" GroupName="Format" Margin="0"
                         IsChecked="{Binding IsMp4Selected}"
                         VerticalContentAlignment="Center"
                         AutomationProperties.AutomationId="Mp4Radio"/>
        </StackPanel>

        <Grid Grid.Row="2" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Label Content="저장 폴더" Grid.Column="0"/>
            <TextBox Grid.Column="1" Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.AutomationId="FolderTextBox"/>
            <Button Grid.Column="2" Content="찾아보기" Command="{Binding BrowseFolderCommand}"
                    AutomationProperties.AutomationId="BrowseButton"/>
            <Button Grid.Column="3" Content="폴더 열기" Command="{Binding OpenFolderCommand}"
                    AutomationProperties.AutomationId="OpenFolderButton"/>
        </Grid>

        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,14">
            <Button Content="변환 시작" Command="{Binding StartCommand}"
                    MinWidth="120" FontWeight="Bold"
                    AutomationProperties.AutomationId="StartButton"/>
            <Button Content="취소" Command="{Binding CancelCommand}"
                    MinWidth="80"
                    AutomationProperties.AutomationId="CancelButton"/>
        </StackPanel>

        <GroupBox Grid.Row="4" Header="진행 상황" Padding="8" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="{Binding VideoTitle}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                <TextBlock Text="{Binding StatusText}" Margin="0,4,0,6"/>
                <ProgressBar Value="{Binding Progress}" Maximum="1.0" Height="18"
                             AutomationProperties.AutomationId="ProgressBar"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Grid.Row="5" Header="로그">
            <ListBox ItemsSource="{Binding LogLines}"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     FontFamily="Consolas" FontSize="11"
                     AutomationProperties.AutomationId="LogList"/>
        </GroupBox>
    </Grid>
</Window>
